import os

# Constants for the game board
ROWS = 6
COLS = 7

def create_board():
    """Creates an empty 6x7 board filled with spaces."""
    return [[" " for _ in range(COLS)] for _ in range(ROWS)]

def print_board(board):
    """Clears the terminal and prints the current board state."""
    # Clears terminal for a cleaner look (works on Windows/Mac/Linux)
    os.system('cls' if os.name == 'nt' else 'clear')
    
    print("\n  0   1   2   3   4   5   6")  # Column headers
    print("+---+---+---+---+---+---+---+")
    for row in board:
        print("| " + " | ".join(row) + " |")
        print("+---+---+---+---+---+---+---+")
    print()

def is_valid_location(board, col):
    """Checks if the top row of a column is empty."""
    return board[0][col] == " "

def get_next_open_row(board, col):
    """Finds the lowest available row in a given column."""
    for r in range(ROWS - 1, -1, -1):
        if board[r][col] == " ":
            return r

def drop_piece(board, row, col, piece):
    """Places the player's piece in the specified cell."""
    board[row][col] = piece

def check_win(board, piece):
    """Checks the board for 4-in-a-row in all directions."""
    # 1. Check horizontal locations
    for c in range(COLS - 3):
        for r in range(ROWS):
            if board[r][c] == piece and board[r][c+1] == piece and board[r][c+2] == piece and board[r][c+3] == piece:
                return True

    # 2. Check vertical locations
    for c in range(COLS):
        for r in range(ROWS - 3):
            if board[r][c] == piece and board[r+1][c] == piece and board[r+2][c] == piece and board[r+3][c] == piece:
                return True

    # 3. Check positively sloped diagonals (bottom-left to top-right)
    for c in range(COLS - 3):
        for r in range(3, ROWS):
            if board[r][c] == piece and board[r-1][c+1] == piece and board[r-2][c+2] == piece and board[r-3][c+3] == piece:
                return True

    # 4. Check negatively sloped diagonals (top-left to bottom-right)
    for c in range(COLS - 3):
        for r in range(ROWS - 3):
            if board[r][c] == piece and board[r+1][c+1] == piece and board[r+2][c+2] == piece and board[r+3][c+3] == piece:
                return True

    return False

def is_board_full(board):
    """Checks if there are no remaining empty spaces."""
    for c in range(COLS):
        if board[0][c] == " ":
            return False
    return True

def play_game():
    board = create_board()
    game_over = False
    turn = 0  # 0 for Player 1, 1 for Player 2
    
    players = ["X", "O"]
    
    while not game_over:
        print_board(board)
        current_piece = players[turn]
        print(f"Player {turn + 1} ({current_piece})'s Turn.")
        
        # Get and validate user input
        try:
            col = int(input("Choose a column (0-6): "))
            if col < 0 or col >= COLS:
                print("Invalid column! Please choose a number between 0 and 6.")
                input("Press Enter to try again...")
                continue
        except ValueError:
            print("Please enter a valid integer.")
            input("Press Enter to try again...")
            continue
            
        # Check if the column has room
        if is_valid_location(board, col):
            row = get_next_open_row(board, col)
            drop_piece(board, row, col, current_piece)
            
            # Check for win condition
            if check_win(board, current_piece):
                print_board(board)
                print(f"🎉 Congratulations! Player {turn + 1} ({current_piece}) wins! 🎉")
                game_over = True
            # Check for a tie
            elif is_board_full(board):
                print_board(board)
                print("It's a tie game! 🤝")
                game_over = True
                
            # Switch turns
            turn = (turn + 1) % 2
        else:
            print("That column is full! Choose another one.")
            input("Press Enter to try again...")

if __name__ == "__main__":
    play_game()
